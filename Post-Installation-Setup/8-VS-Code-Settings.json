{
  // ===== APPEARANCE & THEMES =====
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "One Dark Pro Night Flat",
  "oneDarkPro.editorTheme": "One Dark Pro Night Flat",
  "workbench.preferredDarkColorTheme": "One Dark Pro Night Flat",
  "workbench.preferredHighContrastColorTheme": "One Dark Pro Night Flat",
  "workbench.preferredHighContrastLightColorTheme": "One Dark Pro Night Flat",
  "workbench.preferredLightColorTheme": "One Dark Pro Night Flat",
  // ===== EDITOR BEHAVIOR & PERFORMANCE =====
  "editor.inlineSuggest.suppressSuggestions": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "editor.mouseWheelZoom": true,
  "editor.largeFileOptimizations": false,
  "editor.minimap.autohide": "mouseover",
  "editor.renderWhitespace": "all",
  "workbench.editor.enablePreview": false,
  "breadcrumbs.enabled": false,
  "editor.rulers": [
    80,
    120
  ],
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  // ===== MODERN INTELLISENSE & SUGGESTIONS =====
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.suggestOnTriggerCharacters": true,
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.suggest.insertMode": "insert",
  "editor.suggest.filterGraceful": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.parameterHints.enabled": true,
  "editor.hover.enabled": "on",
  "editor.hover.delay": 300,
  // ===== MODERN BRACKET & GUIDE ENHANCEMENTS =====
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.indentation": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  // ===== TYPOGRAPHY & VISUAL STYLING =====
  "editor.fontFamily": "'FiraCode Nerd Font', 'FiraCode NF', 'Noto Sans Mono', 'Cascadia Code', Consolas, monospace",
  "editor.lineHeight": 1.5,
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.cursorBlinking": "blink",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.renderLineHighlight": "none",
  "editor.smoothScrolling": true,
  "editor.cursorWidth": 2,
  // ===== TERMINAL CONFIGURATION (Enhanced for Linux) =====
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font', 'Noto Sans Mono', 'Cascadia Code', monospace",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.env.linux": {
    "TERM": "xterm-256color"
  },
  // ===== CODE RUNNER SETTINGS =====
  "code-runner.clearPreviousOutput": true,
  "code-runner.showExecutionMessage": false,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.ignoreSelection": false,
  // ===== LANGUAGE-SPECIFIC CONFIGURATIONS =====
  "[python]": {
    "editor.semanticHighlighting.enabled": false,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.rulers": [
      88,
      120
    ],
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[sql]": {
    "editor.defaultFormatter": "ms-mssql.mssql",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  // ===== SEMANTIC HIGHLIGHTING (Enhanced but controlled) =====
  "editor.semanticHighlighting.enabled": false,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "parameter.python": "#e5c07b",
      "variable.readonly.python": "#d19a66",
      "class.python": "#e06c75"
    }
  },
  // ===== CUSTOM TOKEN COLORS =====
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Strings (Soft and readable)",
        "scope": [
          "string",
          "string.quoted",
          "string.quoted.double",
          "string.quoted.single",
          "string.template"
        ],
        "settings": {
          "foreground": "#d19a66",
          "fontStyle": ""
        }
      },
      {
        "name": "Numbers",
        "scope": "constant.numeric",
        "settings": {
          "foreground": "#b5cea8"
        }
      },
      {
        "name": "Python Booleans and None (Distinctive coral)",
        "scope": [
          "constant.language.boolean.python",
          "constant.language.python"
        ],
        "settings": {
          "foreground": "#e06c75"
        }
      },
      {
        "name": "Python Functions and Methods (Unified blue)",
        "scope": [
          "entity.name.function.python",
          "entity.name.method.python",
          "support.function.builtin.python",
          "support.function.magic.python",
          "support.function.method.python",
          "meta.function-call.generic.python",
          "meta.function-call.method.python"
        ],
        "settings": {
          "foreground": "#61afef",
          "fontStyle": ""
        }
      },
      {
        "name": "Python Keywords",
        "scope": [
          "keyword.control.import.python",
          "keyword.control.flow.python",
          "storage.type.function.python",
          "storage.type.class.python",
          "keyword.other.python"
        ],
        "settings": {
          "foreground": "#bd93f9"
        }
      },
      {
        "name": "Python Decorators (Special highlighting)",
        "scope": [
          "entity.name.function.decorator.python",
          "meta.function.decorator.python"
        ],
        "settings": {
          "foreground": "#c678dd",
          "fontStyle": "italic"
        }
      },
      {
        "name": "SQL Objects (Tables, columns, etc.)",
        "scope": [
          "constant.other.database-name.sql",
          "constant.other.table-name.sql",
          "source.sql",
          "entity.name.table.sql",
          "entity.name.column.sql",
          "variable.parameter.sql"
        ],
        "settings": {
          "foreground": "#8faadc",
          "fontStyle": ""
        }
      },
      {
        "name": "JSON Booleans",
        "scope": [
          "constant.language.boolean.json",
          "constant.language.json"
        ],
        "settings": {
          "foreground": "#bd93f9"
        }
      },
      {
        "name": "Comments (Subtle but readable)",
        "scope": [
          "comment",
          "comment.line",
          "comment.block"
        ],
        "settings": {
          "foreground": "#7c7c7c",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Variables and Constants",
        "scope": [
          "variable",
          "variable.other.readwrite",
          "variable.other.constant",
          "variable.language",
          "variable.parameter",
          "variable.other.enummember",
          "source.python"
        ],
        "settings": {
          "foreground": "#a8b5d1"
        }
      },
      {
        "name": "General Constants (excluding language-specific)",
        "scope": [
          "constant.character",
          "constant.other"
        ],
        "settings": {
          "foreground": "#abb2bf"
        }
      }
    ]
  },
  // ===== WORKSPACE COLORS (Modern settings) =====
  "workbench.colorCustomizations": {
    "statusBarItem.remoteBackground": "#2e2e2e",
    "statusBarItem.remoteForeground": "#a0a0a0",
    "editor.selectionBackground": "#214283cc",
    "editor.wordHighlightStrongBackground": "#214283cc",
    "editor.wordHighlightStrongForeground": "#ffffff",
    "editor.wordHighlightBackground": "#bbbbbb33",
    "editor.wordHighlightForeground": "#bbbbbb",
    "editor.selectionHighlightBorder": "#00000000",
    "editor.wordHighlightBorder": "#00000000",
    "editor.wordHighlightStrongBorder": "#00000000",
    "errorLens.errorBackground": "#00000000",
    "errorLens.warningBackground": "#00000000",
    "editorWarning.background": "#00000000",
    "editorInfo.background": "#00000000",
    "editorHint.background": "#00000000",
    "editorGutter.warningBackground": "#00000000",
    "editorGutter.errorBackground": "#00000000",
    "editor.lineHighlightBorder": "#00000000",
    // Modern indent guide colors (using background1 for compatibility)
    "editorIndentGuide.background1": "#404040",
    "editorIndentGuide.activeBackground1": "#707070",
    // Bracket pair colors
    "editorBracketHighlight.foreground1": "#ffd700",
    "editorBracketHighlight.foreground2": "#da70d6",
    "editorBracketHighlight.foreground3": "#87ceeb",
    "editorBracketHighlight.foreground4": "#ffd700",
    "editorBracketHighlight.foreground5": "#da70d6",
    "editorBracketHighlight.foreground6": "#87ceeb"
  },
  // ===== PERFORMANCE OPTIMIZATIONS (Ubuntu/Linux Optimized) =====
  "update.mode": "none",
  "update.showReleaseNotes": false,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": false,
  "telemetry.telemetryLevel": "off",
  "workbench.enableExperiments": false,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "search.followSymlinks": false,
  "search.useIgnoreFiles": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.hg/store/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.tox/**": true,
    "**/venv/**": true,
    "**/.coverage": true,
    "**/.env": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.coverage": true,
    "**/*.pyc": true,
    "**/.DS_Store": true
  },
  // ===== SPELL CHECKING (Modern settings) =====
  "cSpell.userWords": [
    "Bijoy",
    "Bijoy Nandi",
    "Nandi"
  ],
  "cSpell.enabledFileTypes": {
    "markdown": true,
    "python": true,
    "sql": true
  },
  "cSpell.diagnosticLevel": "Hint",
  // ===== GIT INTEGRATION =====
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.autofetchPeriod": 180,
  "git.decorations.enabled": true,
  "git.enableStatusBarSync": true,
  "diffEditor.ignoreTrimWhitespace": false,
  // ===== PYTHON ANALYSIS SETTINGS =====
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.diagnosticMode": "workspace",
  // ===== DRAWIO SETTINGS =====
  "hediet.vscode-drawio.resizeImages": null,
  "hediet.vscode-drawio.theme": "kennedy",
  "hediet.vscode-drawio.appearance": "automatic",
  // ===== AREPL SETTINGS =====
  "AREPL.showFooter": false,
  "AREPL.delay": 300,
  // ===== ERROR LENS ENHANCEMENTS =====
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning"
  ],
  "errorLens.fontSize": "13px",
  "errorLens.fontStyleItalic": true,
  "errorLens.delay": 500,
  // ===== SQL SERVER CONFIGURATION =====
  "mssql.connectionGroups": [
